<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" colorMatched="YES" initialViewController="launch-view-controller">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23506"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <scene sceneID="launch-scene">
            <objects>
                <viewController id="launch-view-controller" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="launch-view">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="logo-card">
                                <rect key="frame" x="142" y="337" width="109" height="109"/>
                                <subviews>
                                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" image="WayfarerLogo" translatesAutoresizingMaskIntoConstraints="NO" id="logo-image">
                                        <rect key="frame" x="14" y="14" width="81" height="81"/>
                                        <constraints>
                                            <constraint firstAttribute="width" secondItem="logo-image" secondAttribute="height" multiplier="1:1" id="logo-square"/>
                                        </constraints>
                                    </imageView>
                                </subviews>
                                <color key="backgroundColor" red="0.021999999999999999" green="0.34900000000000003" blue="0.41999999999999998" alpha="0.5" colorSpace="custom" customColorSpace="sRGB"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="109" id="logo-card-width"/>
                                    <constraint firstAttribute="height" constant="109" id="logo-card-height"/>
                                    <constraint firstItem="logo-image" firstAttribute="centerX" secondItem="logo-card" secondAttribute="centerX" id="logo-image-center-x"/>
                                    <constraint firstItem="logo-image" firstAttribute="centerY" secondItem="logo-card" secondAttribute="centerY" id="logo-image-center-y"/>
                                    <constraint firstItem="logo-image" firstAttribute="width" secondItem="logo-card" secondAttribute="width" multiplier="0.74" id="logo-image-width"/>
                                </constraints>
                            </view>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Wayfarer" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" translatesAutoresizingMaskIntoConstraints="NO" id="title-label">
                                <rect key="frame" x="70" y="472" width="253" height="43"/>
                                <fontDescription key="fontDescription" type="system" weight="heavy" pointSize="36"/>
                                <color key="textColor" red="0.080000000000000002" green="0.12" blue="0.16" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Trips ready. Safety ready. Memories unlocked." textAlignment="center" lineBreakMode="wordWrap" numberOfLines="2" baselineAdjustment="alignBaselines" translatesAutoresizingMaskIntoConstraints="NO" id="subtitle-label">
                                <rect key="frame" x="47" y="524" width="299" height="40"/>
                                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="16"/>
                                <color key="textColor" red="0.28000000000000003" green="0.32000000000000001" blue="0.37" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>
                            <stackView opaque="NO" contentMode="scaleToFill" distribution="fillEqually" spacing="8" translatesAutoresizingMaskIntoConstraints="NO" id="badge-stack">
                                <rect key="frame" x="70" y="604" width="253" height="10"/>
                                <subviews>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="badge-1">
                                        <rect key="frame" x="0.0" y="0.0" width="79" height="10"/>
                                        <color key="backgroundColor" red="0.0" green="0.55000000000000004" blue="0.57999999999999996" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                    </view>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="badge-2">
                                        <rect key="frame" x="87" y="0.0" width="79" height="10"/>
                                        <color key="backgroundColor" red="0.95999999999999996" green="0.42999999999999999" blue="0.23999999999999999" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                    </view>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="badge-3">
                                        <rect key="frame" x="174" y="0.0" width="79" height="10"/>
                                        <color key="backgroundColor" red="0.45000000000000001" green="0.39000000000000001" blue="0.78000000000000003" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                    </view>
                                </subviews>
                                <constraints>
                                    <constraint firstAttribute="height" constant="10" id="badge-stack-height"/>
                                </constraints>
                            </stackView>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="safe-area"/>
                        <color key="backgroundColor" red="0.93000000000000005" green="0.97999999999999998" blue="0.97999999999999998" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="logo-card" firstAttribute="centerX" secondItem="launch-view" secondAttribute="centerX" id="logo-center-x"/>
                            <constraint firstItem="logo-card" firstAttribute="centerY" secondItem="launch-view" secondAttribute="centerY" constant="-88" id="logo-center-y"/>
                            <constraint firstItem="title-label" firstAttribute="top" secondItem="logo-card" secondAttribute="bottom" constant="26" id="title-top"/>
                            <constraint firstItem="title-label" firstAttribute="leading" secondItem="safe-area" secondAttribute="leading" constant="34" id="title-leading"/>
                            <constraint firstItem="safe-area" firstAttribute="trailing" secondItem="title-label" secondAttribute="trailing" constant="34" id="title-trailing"/>
                            <constraint firstItem="subtitle-label" firstAttribute="top" secondItem="title-label" secondAttribute="bottom" constant="6" id="subtitle-top"/>
                            <constraint firstItem="subtitle-label" firstAttribute="leading" secondItem="safe-area" secondAttribute="leading" constant="38" id="subtitle-leading"/>
                            <constraint firstItem="safe-area" firstAttribute="trailing" secondItem="subtitle-label" secondAttribute="trailing" constant="38" id="subtitle-trailing"/>
                            <constraint firstItem="badge-stack" firstAttribute="top" secondItem="subtitle-label" secondAttribute="bottom" constant="40" id="badge-top"/>
                            <constraint firstItem="badge-stack" firstAttribute="centerX" secondItem="launch-view" secondAttribute="centerX" id="badge-center-x"/>
                            <constraint firstItem="badge-stack" firstAttribute="width" secondItem="launch-view" secondAttribute="width" multiplier="0.64" id="badge-width"/>
